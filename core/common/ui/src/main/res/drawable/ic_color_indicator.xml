<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:id="@+id/background_circle"
        android:start="4dp"
        android:end="4dp"
        android:top="4dp"
        android:bottom="4dp">

        <shape android:shape="oval">
            <solid android:color="@color/overlayMenuButtons" />
        </shape>

    </item>

    <item android:id="@+id/border_circle">

        <shape android:shape="oval">
            <stroke
                android:width="4dp"
                android:color="?attr/colorControlNormal" />
        </shape>

    </item>

</layer-list>