    <string name="message_empty_screen_event_title">¡Sin eventos de pantalla!</string>
    <string name="message_empty_screen_event_desc">Un evento de pantalla contiene un conjunto de acciones ejecutadas cuando se detecta una condición específica en la pantalla.\nNecesita al menos una pantalla o evento desencadenante en su escenario para ejecutarlo.</string>
    <string name="message_empty_trigger_event_list_title">¡Sin eventos desencadenantes!</string>
    <string name="message_empty_trigger_event_list_desc">Un evento desencadenante contiene un conjunto de acciones ejecutadas cuando se cumple un conjunto de condiciones personalizadas.\nNecesita al menos una pantalla o evento desencadenante en su escenario para ejecutarlo.</string>

