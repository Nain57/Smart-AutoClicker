<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/counter_value_layout"
    android:layout_width="match_parent"
    android:layout_height="@dimen/item_height_big">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/icon_counter"
        android:layout_width="@dimen/item_height"
        android:layout_height="@dimen/item_height"
        android:layout_marginEnd ="@dimen/margin_horizontal_small"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/title"
        app:srcCompat="@drawable/ic_change_counter"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/title"
        style="@style/AppTheme.Field.TitleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd ="@dimen/margin_horizontal_default"
        app:layout_constraintBottom_toTopOf="@id/description"
        app:layout_constraintEnd_toStartOf="@+id/chevron"
        app:layout_constraintStart_toEndOf="@id/icon_counter"
        app:layout_constraintTop_toTopOf="@id/icon_counter"
        tools:text="My counter name" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/description"
        style="@style/AppTheme.Field.SubText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/margin_horizontal_default"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintBottom_toBottomOf="@id/icon_counter"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintEnd_toStartOf="@id/chevron"
        android:gravity="center_vertical"
        tools:text="Starting value: 82.00" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/chevron"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_chevron_right"
        tools:ignore="ContentDescription"/>

</androidx.constraintlayout.widget.ConstraintLayout>