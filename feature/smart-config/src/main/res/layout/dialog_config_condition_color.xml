<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/AppTheme.Dialog.BackgroundLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include layout="@layout/include_dialog_navigation_top_bar"
        android:id="@+id/layout_top_bar" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_vertical_large"
            android:layout_marginBottom="@dimen/margin_vertical_extra_large"
            android:orientation="vertical"
            tools:layout_gravity="center">

            <include layout="@layout/include_field_text_input"
                android:id="@+id/field_edit_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_horizontal_default"
                android:layout_marginBottom="@dimen/margin_horizontal_small"
                app:endIconMode="clear_text"
                android:hint="@string/generic_name"/>

            <com.google.android.material.card.MaterialCardView
                style="@style/AppTheme.Widget.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_horizontal_default"
                android:layout_marginBottom="@dimen/margin_vertical_large">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/margin_horizontal_default"
                    android:layout_marginVertical="@dimen/margin_vertical_default"
                    android:orientation="vertical">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/icon_color_value"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_marginVertical="@dimen/margin_vertical_default"
                        android:layout_marginHorizontal="@dimen/margin_horizontal_small"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/color_divider"
                        app:layout_constraintBottom_toTopOf="@id/text_color_value"
                        app:srcCompat="@drawable/ic_color_indicator"/>

                    <TextView
                        android:id="@+id/text_color_value"
                        style="@style/AppTheme.TextAppearance.FieldTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/margin_vertical_default"
                        app:layout_constraintTop_toBottomOf="@id/icon_color_value"
                        app:layout_constraintStart_toStartOf="@id/icon_color_value"
                        app:layout_constraintEnd_toEndOf="@id/icon_color_value"
                        app:layout_constraintBottom_toTopOf="@id/divider_should_appear"
                        app:layout_constraintVertical_chainStyle="packed"
                        android:text="#FFFFFFFF"
                        tools:ignore="HardcodedText" />


                    <com.google.android.material.divider.MaterialDivider
                        android:id="@+id/color_divider"
                        style="@style/AppTheme.Widget.Divider.Vertical"
                        android:layout_width="1dp"
                        android:layout_height="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/icon_color_value"
                        app:layout_constraintEnd_toStartOf="@id/layout_rgb_sliders"
                        app:layout_constraintBottom_toTopOf="@id/divider_should_appear" />

                    <LinearLayout
                        android:id="@+id/layout_rgb_sliders"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/divider_should_appear"
                        app:layout_constraintStart_toEndOf="@id/color_divider"
                        app:layout_constraintEnd_toEndOf="parent">

                        <include layout="@layout/include_rgb_slider"
                            android:id="@+id/slider_red" />
                        <include layout="@layout/include_rgb_slider"
                            android:id="@+id/slider_green" />
                        <include layout="@layout/include_rgb_slider"
                            android:id="@+id/slider_blue" />

                    </LinearLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:id="@+id/divider_should_appear"
                        style="@style/AppTheme.Widget.Divider.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/margin_vertical_small"
                        app:layout_constraintTop_toBottomOf="@id/color_divider"
                        app:layout_constraintBottom_toBottomOf="@id/field_should_appear"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <include layout="@layout/include_field_switch"
                        android:id="@+id/field_should_appear"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_vertical_small"
                        app:layout_constraintTop_toBottomOf="@id/divider_should_appear"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/color_divider"
                        app:layout_constraintEnd_toEndOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/AppTheme.Widget.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_horizontal_default"
                android:layout_marginBottom="@dimen/margin_vertical_large">

                <include layout="@layout/include_field_slider"
                    android:id="@+id/field_slider_threshold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/margin_horizontal_default"
                    android:layout_marginTop="@dimen/margin_vertical_large"
                    android:layout_marginBottom="@dimen/margin_vertical_small"/>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
