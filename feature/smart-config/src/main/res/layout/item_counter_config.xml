<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/AppTheme.Widget.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/margin_horizontal_default"
    android:layout_marginEnd="@dimen/margin_horizontal_default"
    android:layout_marginTop="@dimen/margin_vertical_default"
    android:layout_marginBottom="@dimen/margin_vertical_small">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/margin_horizontal_default"
        android:layout_marginTop="@dimen/margin_vertical_large"
        android:layout_marginBottom="@dimen/margin_vertical_default">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/counter_name"
            style="@style/AppTheme.TextAppearance.ListItemTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_vertical_small"
            app:layout_constraintVertical_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/top_divider"
            app:layout_constraintTop_toTopOf="@id/button_expand_collapse"
            app:layout_constraintBottom_toTopOf="@id/counter_desc"
            tools:text="My cool counter"/>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/counter_desc"
            style="@style/AppTheme.TextAppearance.ListItemSubText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/margin_horizontal_default"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/top_divider"
            app:layout_constraintTop_toBottomOf="@id/counter_name"
            app:layout_constraintBottom_toBottomOf="@id/button_expand_collapse"
            android:gravity="center_vertical"
            tools:text="Referenced by 3 elements"/>

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/top_divider"
            style="@style/AppTheme.Widget.Divider.Vertical"
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_marginEnd="@dimen/margin_horizontal_small"
            app:layout_constraintStart_toEndOf="@id/counter_name"
            app:layout_constraintEnd_toStartOf="@id/button_expand_collapse"
            app:layout_constraintTop_toTopOf="@id/button_expand_collapse"
            app:layout_constraintBottom_toBottomOf="@id/button_expand_collapse"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_expand_collapse"
            style="@style/AppTheme.Widget.IconButton"
            app:layout_constraintStart_toEndOf="@id/top_divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/layout_starting_value"
            app:icon="@drawable/ic_chevron_down"
            tools:visibility="visible"/>

        <include layout="@layout/include_field_text_input"
            android:id="@+id/layout_starting_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/margin_vertical_default"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/button_expand_collapse"
            app:layout_constraintBottom_toTopOf="@id/written_by_button"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/written_by_button"
            style="@style/AppTheme.Widget.IconButtonFilledTonal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_vertical_small"
            android:layout_marginEnd="@dimen/margin_horizontal_mini"
            android:layout_marginStart="-4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/read_by_button"
            app:layout_constraintTop_toBottomOf="@id/layout_starting_value"
            app:layout_constraintBottom_toTopOf="@id/delete_button"
            app:icon="@drawable/ic_write"
            android:maxLines="1"
            tools:text="2 actions"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/read_by_button"
            style="@style/AppTheme.Widget.IconButtonFilledTonal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_horizontal_mini"
            android:layout_marginEnd="-4dp"
            app:layout_constraintStart_toEndOf="@id/written_by_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/written_by_button"
            app:layout_constraintBottom_toBottomOf="@id/written_by_button"
            app:icon="@drawable/ic_read"
            android:maxLines="1"
            tools:text="2 conditions"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/delete_button"
            style="@style/AppTheme.Widget.IconButtonFilled"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_vertical_default"
            android:layout_marginStart="-4dp"
            android:layout_marginEnd="-4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/written_by_button"
            app:layout_constraintBottom_toBottomOf="parent"
            app:icon="@drawable/ic_delete"
            android:maxLines="1"
            tools:text="Delete and replace"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/replace_by_text"
        style="@style/AppTheme.TextAppearance.ListItemTitle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:background="#BBFFFFFF"
        android:text="@string/message_replace_by"/>

</com.google.android.material.card.MaterialCardView>